# Copy this file to .env and fill in values for local development.
# NEVER commit .env to version control.

# Django
SECRET_KEY=your-secret-key-here-generate-with-python-c-import-secrets-print-secrets.token_hex-50
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database
DB_NAME=dcm
DB_USER=dcm_user
DB_PASSWORD=dcm_pass
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-here-generate-separately
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# AWS S3 (leave blank for local dev — files stored locally)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# Sentry (leave blank for local dev)
SENTRY_DSN=

# Public hostname for tenant routing (e.g. "dcm-platform.com")
# In local dev, set to "localhost"
TENANT_BASE_DOMAIN=localhost

# DocuSeal
DOCUSEAL_BASE_URL=http://localhost:8081
DOCUSEAL_SSO_SECRET=your-docuseal-sso-secret-here
DOCUSEAL_WEBHOOK_SECRET=your-docuseal-webhook-secret-here
